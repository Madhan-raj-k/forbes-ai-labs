# Supabase (optional — portfolio falls back to lib/projects.ts if unset)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin dashboard
ADMIN_PASSWORD=your-secure-password

# Resend Email (required for contact form)
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_your_api_key_here

# Sender address — must be a verified domain in Resend
# For testing, use: Codeify <onboarding@resend.dev>
RESEND_FROM_EMAIL=Codeify <onboarding@resend.dev>

# Team inbox for contact form submissions
CONTACT_EMAIL=teamcodeify@gmail.com